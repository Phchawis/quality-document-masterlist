# --- Database ---
# PostgreSQL connection string (Neon / Supabase / on-prem all work)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# --- Auth ---
# Generate with: openssl rand -base64 32
SESSION_SECRET=""

# Shared secret for signing single-sign-on handoff links to the standalone MedTech
# app (Wedapp LAB). Must match SSO_SHARED_SECRET in that app's env exactly.
# Generate with: openssl rand -base64 32
# Leave empty to disable SSO handoff — the MEDTECH link then opens Wedapp LAB's
# own login screen with no pre-filled session.
SSO_SHARED_SECRET=""

# --- File storage ---
# Directory where attachment files are stored (mount a volume here in Docker)
UPLOAD_DIR="./uploads"

# --- Seeding ---
# "1" seeds demo documents for testing; "0" seeds only reference data + admin user
SEED_DEMO="0"

# --- HTTPS (docker-compose only) ---
# Public hostname Caddy will request a Let's Encrypt certificate for.
SITE_DOMAIN="example.duckdns.org"
